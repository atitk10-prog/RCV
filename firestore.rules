rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Sessions collection for real-time sync
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
